{
   "name": "quiz",
   "version": "1.0.0",
   "main": "index.js",
   "type": "module",
   "scripts": {
      "dev": "nodemon",
      "start": "cross-env NODE_ENV=production node ./dist/src/index.js",
      "build": "swc src --out-dir dist --ignore **/*.test.ts",
      "lint": "npx eslint ./src",
      "format": "npx prettier ./src --write",
      "prepare": "husky",
      "test": "jest",
      "typeorm": "typeorm-ts-node-esm",
      "migration:generate": "cross-env NODE_ENV=development typeorm-ts-node-esm -d src/data-source.ts migration:generate",
      "migration:run": "cross-env NODE_ENV=development typeorm-ts-node-esm -d src/data-source.ts migration:run"
   },
   "keywords": [
      "quiz"
   ],
   "author": "Yash Gajanan Bansod",
   "license": "MIT",
   "description": "",
   "devDependencies": {
      "@commitlint/cli": "^19.6.0",
      "@commitlint/config-conventional": "^19.6.0",
      "@eslint/js": "^9.16.0",
      "@swc/cli": "^0.5.2",
      "@swc/core": "^1.10.0",
      "@swc/jest": "^0.2.37",
      "@types/bcrypt": "^5.0.2",
      "@types/eslint__js": "^8.42.3",
      "@types/express": "^5.0.0",
      "@types/jest": "^29.5.14",
      "@types/jsonwebtoken": "^9.0.7",
      "@types/morgan": "^1.9.9",
      "@types/node": "^22.10.1",
      "@types/nodemailer": "^6.4.17",
      "@types/supertest": "^6.0.2",
      "eslint": "^9.16.0",
      "husky": "^9.1.7",
      "jest": "^29.7.0",
      "lint-staged": "^15.2.10",
      "nodemon": "^3.1.7",
      "prettier": "3.4.2",
      "supertest": "^7.0.0",
      "ts-jest": "^29.2.5",
      "tsconfig-paths": "^4.2.0",
      "tsx": "^4.19.2",
      "typescript": "5.7.2",
      "typescript-eslint": "^8.17.0"
   },
   "dependencies": {
      "@google/generative-ai": "^0.21.0",
      "bcrypt": "^5.1.1",
      "cross-env": "^7.0.3",
      "dotenv": "^16.4.7",
      "express": "^4.21.2",
      "helmet": "^8.0.0",
      "http-errors": "^2.0.0",
